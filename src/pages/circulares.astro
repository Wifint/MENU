---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Circulares" currentPage="circulares">
  <div slot="header">
    <div>
      <h1>TECNET.C.A.</h1>
      <p>Circulares y Comunicados</p>
    </div>
  </div>
  
  <div class="container">
    <h2 class="section-title">Comunicados Oficiales</h2>

    <div id="loadingSpinner" class="loading-spinner">
      <i class="fas fa-spinner fa-spin"></i> Cargando circulares...
    </div>

    <div id="errorMessage" class="error-message" style="display: none;"></div>

    <div id="circularesGrid" class="url-grid"></div>

    <div id="paginationContainer" class="pagination-container" style="display: none;">
      <div id="paginationInfo" class="pagination-info"></div>
      <div id="paginationButtons" class="pagination-buttons"></div>
    </div>
  </div>
</Layout>

<style>
  .container {
    flex: 1;
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem;
    width: 100%;
  }

  .section-title {
    color: var(--primary-color);
    border-bottom: 2px solid var(--primary-color);
    padding-bottom: 0.5rem;
    margin-bottom: 2rem;
  }

  .url-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .url-card {
    background: white;
    padding: 1.5rem;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    display: flex;
    justify-content: space-between;
    align-items: center;
    text-decoration: none;
    color: inherit;
    transition: all 0.3s ease;
    border: 1px solid transparent;
  }

  .url-card:hover {
    border-color: var(--primary-color);
    transform: scale(1.01);
    box-shadow: 0 4px 12px rgba(0, 86, 179, 0.1);
  }

  .url-info h3 {
    margin: 0;
    color: var(--primary-color);
    font-size: 1.1rem;
  }

  .url-info p {
    margin: 0.3rem 0 0;
    font-size: 0.9rem;
    color: #666;
  }

  .url-icon {
    font-size: 1.5rem;
    color: var(--primary-color);
  }

  .pagination-container {
    margin-top: 3rem;
    padding: 2rem 0;
    border-top: 1px solid #eee;
  }

  .pagination-info {
    text-align: center;
    color: #666;
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
    font-weight: 500;
  }

  .pagination-buttons {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .page-btn {
    min-width: 40px;
    height: 40px;
    padding: 0.5rem 1rem;
    border: 1px solid #ddd;
    background: white;
    color: #333;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.3s ease;
    font-size: 0.9rem;
    font-weight: 500;
  }

  .page-btn:hover:not(:disabled) {
    background: var(--primary-color);
    color: white;
    border-color: var(--primary-color);
    transform: translateY(-2px);
    box-shadow: 0 4px 8px rgba(0, 86, 179, 0.2);
  }

  .page-btn.active {
    background: var(--primary-color);
    color: white;
    border-color: var(--primary-color);
    font-weight: 600;
  }

  .page-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .page-btn.last-btn {
    padding: 0.5rem 1.2rem;
  }

  .loading-spinner {
    text-align: center;
    padding: 3rem;
    color: var(--primary-color);
    font-size: 1.1rem;
  }

  .error-message {
    text-align: center;
    padding: 2rem;
    color: #d32f2f;
    background: #ffebee;
    border-radius: 8px;
    margin: 2rem 0;
  }

  @media (max-width: 768px) {
    .pagination-buttons {
      gap: 0.3rem;
    }

    .page-btn {
      min-width: 35px;
      height: 35px;
      padding: 0.4rem 0.8rem;
      font-size: 0.85rem;
    }
  }
</style>

<script>
  const API_URL = '/api/circulares';
  const RECORDS_PER_PAGE = 10;
  let currentPage = 1;

  async function loadCirculares(page = 1) {
    const loadingSpinner = document.getElementById('loadingSpinner')!;
    const errorMessage = document.getElementById('errorMessage')!;
    const circularesGrid = document.getElementById('circularesGrid')!;
    const paginationContainer = document.getElementById('paginationContainer')!;

    loadingSpinner.style.display = 'block';
    errorMessage.style.display = 'none';
    circularesGrid.innerHTML = '';
    paginationContainer.style.display = 'none';

    try {
      const response = await fetch(`${API_URL}?page=${page}&limit=${RECORDS_PER_PAGE}`);
      const result = await response.json();

      if (!result.success) {
        throw new Error(result.error || 'Error al cargar los datos');
      }

      loadingSpinner.style.display = 'none';
      renderCirculares(result.data);

      if (result.pagination.total_records > 0) {
        renderPagination(
          result.pagination.current_page,
          result.pagination.total_pages,
          result.pagination.from,
          result.pagination.to,
          result.pagination.total_records
        );
        paginationContainer.style.display = 'block';
      }

      currentPage = result.pagination.current_page;
      window.scrollTo({ top: 0, behavior: 'smooth' });

    } catch (error: any) {
      console.error('Error al cargar circulares:', error);
      loadingSpinner.style.display = 'none';
      errorMessage.textContent = `Error: ${error.message}. Por favor, verifica que el servidor esté funcionando.`;
      errorMessage.style.display = 'block';
    }
  }

  function renderCirculares(circulares: any[]) {
    const circularesGrid = document.getElementById('circularesGrid')!;

    if (circulares.length === 0) {
      circularesGrid.innerHTML = '<p style="text-align: center; color: #666; padding: 2rem;">No hay circulares disponibles.</p>';
      return;
    }

    circularesGrid.innerHTML = circulares.map(circular => `
      <a href="${escapeHtml(circular.url)}" target="_blank" class="url-card">
        <div class="url-info">
          <h3>${escapeHtml(circular.titulo)}</h3>
          <p>${escapeHtml(circular.descripcion || '')}</p>
        </div>
        <div class="url-icon"><i class="fas fa-file-pdf"></i></div>
      </a>
    `).join('');
  }

  function renderPagination(currentPage: number, totalPages: number, from: number, to: number, totalRecords: number) {
    const paginationInfo = document.getElementById('paginationInfo')!;
    const paginationButtons = document.getElementById('paginationButtons')!;

    paginationInfo.textContent = `Mostrando registros del ${from} al ${to} de un total de ${totalRecords}`;

    let buttonsHTML = '';
    const maxButtons = 5;
    let startPage = Math.max(1, currentPage - Math.floor(maxButtons / 2));
    let endPage = Math.min(totalPages, startPage + maxButtons - 1);

    if (endPage - startPage < maxButtons - 1) {
      startPage = Math.max(1, endPage - maxButtons + 1);
    }

    if (currentPage > 1) {
      buttonsHTML += `<button class="page-btn" data-page="1">Primera</button>`;
    }

    for (let i = startPage; i <= endPage; i++) {
      const activeClass = i === currentPage ? 'active' : '';
      buttonsHTML += `<button class="page-btn ${activeClass}" data-page="${i}">${i}</button>`;
    }

    if (currentPage < totalPages) {
      buttonsHTML += `<button class="page-btn last-btn" data-page="${totalPages}">Última</button>`;
    }

    paginationButtons.innerHTML = buttonsHTML;

    paginationButtons.querySelectorAll('.page-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const page = parseInt(btn.getAttribute('data-page') || '1');
        if (page !== currentPage) {
          loadCirculares(page);
        }
      });
    });
  }

  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  document.addEventListener('DOMContentLoaded', () => {
    loadCirculares(1);
  });
</script>
